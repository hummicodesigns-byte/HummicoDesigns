---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Navbar from '../components/Navbar.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
import FixedButton from '../components/FixedButton.astro';

// `description` is optional — when passed (e.g. by blog pages) it renders a meta
// description for SEO. Existing pages that don't pass it are unaffected.
const { title = 'HummicoDesigns', description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="font-jakarta smooth-scroll">
    <TopBar />
    <Navbar />
    <main>
      <slot />
    </main>
    <Newsletter />
    <Footer />
    <FixedButton />
  </body>
</html>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Newest first.
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Blog · Hummico Designs"
  description="The Hummico journal — gentle guides to brewing loose-leaf herbal tea, calming botanical blends, and the little rituals behind our hand-packed gift boxes from Houston, Texas."
>
  <!-- ════════════════ HERO ════════════════ -->
  <!-- TODO_HUMMICO: Replace the placeholder background on .bhero-bg with the real
       Blog hero image (calming/lifestyle, ~1920x1080). Keep the dark overlay gradient. -->
  <section class="bhero" aria-label="The Hummico journal">
    <div class="bhero-bg" data-placeholder="blog-hero-image"></div>
    <div class="bhero-overlay">
      <p class="bhero-eyebrow">The Hummico journal</p>
      <h1 class="bhero-headline">Stories, rituals<br /><span>&amp; little guides.</span></h1>
      <p class="bhero-sub">
        Slow brewing notes, calming botanicals, and the thinking behind our
        hand-packed boxes — written for tea lovers who like to savour the details.
      </p>
    </div>
  </section>

  <!-- ════════════════ ARTICLE GRID ════════════════ -->
  <section class="section" aria-label="Articles">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => (
          <article class="post-card">
            <a class="post-card-link" href={`/blog/${post.id}`} aria-label={`Read: ${post.data.title}`}>
              <div class="post-card-media">
                {post.data.image
                  ? <img src={post.data.image} alt={post.data.title} class="post-card-img" loading="lazy" />
                  : <div class="post-card-ph img-placeholder"><span>TODO_HUMMICO<br />article image</span></div>}
              </div>
              <div class="post-card-body">
                <time class="post-card-date" datetime={post.data.pubDate.toISOString()}>
                  {fmtDate(post.data.pubDate)}
                </time>
                <h2 class="post-card-title">{post.data.title}</h2>
                <p class="post-card-excerpt">{post.data.excerpt}</p>
                <span class="post-card-read">
                  Read
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- The shared <Newsletter /> is rendered by BaseLayout, above the shared <Footer />. -->
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .section { background-color: #faf6f0; padding: 100px 0; }

  /* ── HERO ── */
  .bhero {
    position: relative;
    width: 100%;
    margin-top: 160px;
    min-height: calc(66vh - 160px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .bhero-bg {
    position: absolute;
    inset: 0;
    background-color: #225234;
    /* Placeholder brand gradient — replace with the real photo (see TODO above). */
    background-image:
      radial-gradient(circle at 24% 28%, rgba(228,145,166,0.32) 0%, transparent 46%),
      radial-gradient(circle at 80% 76%, rgba(45,107,71,0.55) 0%, transparent 52%),
      linear-gradient(150deg, #1c4429 0%, #225234 45%, #2d6b47 100%);
    background-size: cover;
    background-position: center;
  }
  .bhero-overlay {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
    width: 100%;
    min-height: calc(66vh - 160px);
    background: linear-gradient(to bottom, rgba(0,0,0,0.12) 0%, rgba(0,0,0,0.34) 55%, rgba(0,0,0,0.52) 100%);
  }
  .bhero-eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #e491a6;
    font-size: clamp(0.6rem, 1.2vw, 0.78rem);
    margin-bottom: 20px;
  }
  .bhero-headline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-style: italic;
    color: #ffffff;
    line-height: 1.08;
    font-size: clamp(2.6rem, 6.4vw, 5.6rem);
    margin-bottom: 10px;
    max-width: 900px;
  }
  .bhero-headline span { font-style: normal; font-weight: 600; color: #f5e8d8; }
  .bhero-sub {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    color: rgba(255,255,255,0.82);
    font-size: clamp(0.85rem, 1.5vw, 1.05rem);
    letter-spacing: 0.04em;
    margin-top: 16px;
    max-width: 560px;
    line-height: 1.8;
  }

  /* ── ARTICLE GRID ── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .post-card {
    background-color: #ffffff;
    border: 1px solid rgba(34, 82, 52, 0.08);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 14px 40px rgba(34, 82, 52, 0.06);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }
  .post-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 26px 56px rgba(34, 82, 52, 0.14);
  }
  .post-card-link { display: flex; flex-direction: column; height: 100%; text-decoration: none; }
  .post-card-media { position: relative; aspect-ratio: 16 / 10; overflow: hidden; }
  .post-card-img,
  .post-card-ph { width: 100%; height: 100%; object-fit: cover; display: block; }
  .post-card:hover .post-card-img { transform: scale(1.05); }
  .post-card-img { transition: transform 0.6s ease; }
  .post-card-ph {
    flex-direction: column;
    text-align: center;
    font-family: 'Jost', sans-serif;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.6rem;
    line-height: 1.6;
    opacity: 0.65;
  }
  .post-card-body { display: flex; flex-direction: column; flex: 1; padding: 24px 24px 26px; }
  .post-card-date {
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.64rem;
    color: #e491a6;
    margin-bottom: 12px;
  }
  .post-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1.18;
    color: #225234;
    margin: 0 0 12px;
  }
  .post-card-excerpt {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #225234;
    opacity: 0.82;
    margin: 0 0 20px;
    flex: 1;
  }
  .post-card-read {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: auto;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.74rem;
    color: #225234;
    transition: gap 0.25s ease, color 0.25s ease;
  }
  .post-card:hover .post-card-read { color: #e491a6; gap: 12px; }

  /* ── Responsive ── */
  @media (max-width: 1024px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .section { padding: 70px 0; }
    .bhero { margin-top: 130px; min-height: calc(56vh - 130px); }
    .bhero-overlay { min-height: calc(56vh - 130px); padding: 60px 22px; }
    .bhero-eyebrow { letter-spacing: 0.22em; }
  }
  @media (max-width: 560px) { .blog-grid { grid-template-columns: 1fr; } }
</style>

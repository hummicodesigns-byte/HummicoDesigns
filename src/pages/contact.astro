---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../lib/seo';

// ─────────────────────────────────────────────────────────────────────────────
// CONTACT PAGE
// All copy below is real static HTML (good for SEO); JS is used ONLY to submit the
// form via Web3Forms without leaving the page.
//
// SETUP: paste your real Web3Forms access key into the hidden "access_key" input
// (search for YOUR_WEB3FORMS_KEY below). Get a free key at https://web3forms.com
// ─────────────────────────────────────────────────────────────────────────────

const EMAIL = 'Hummicodesigns@gmail.com';
const INSTAGRAM = 'https://www.instagram.com/hummico_designs/';
const ETSY = 'https://www.etsy.com/shop/HummicoDesigns';
const PINTEREST = 'https://www.pinterest.com/hummicodesigns/';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Contact', path: '/contact/' },
  ]),
];
---

<BaseLayout
  title="Contact Hummico Designs — Houston, TX"
  description="Have a question, custom order or just a hello? Reach out to Hummico Designs, a sister-owned herbal tea gift studio based in Houston, TX — we read every message ourselves."
  schemas={schemas}
>
  <!-- ════════════════ 1. HERO ════════════════ -->
  <!-- TODO_HUMMICO: Replace the placeholder background on .chero-bg with the real
       Contact hero image (calming/lifestyle, ~1920x1080). Keep the dark overlay
       gradient in .chero-overlay for text legibility — same treatment as the other pages. -->
  <section class="chero" aria-label="Contact Hummico Designs">
    <div class="chero-bg" data-placeholder="contact-hero-image"></div>
    <div class="chero-overlay">
      <p class="chero-eyebrow">We'd love to hear from you</p>
      <h1 class="chero-headline">Get in<br /><span>touch.</span></h1>
      <p class="chero-sub">
        Questions, custom orders, or just a hello reach out and one of the sisters
        will get back to you soon.
      </p>
    </div>
  </section>

  <!-- ════════════════ 2. CONTACT INFO + FORM ════════════════ -->
  <section class="section contact" aria-label="Contact details and message form">
    <div class="container">
      <div class="contact-grid">
        <!-- LEFT: contact info -->
        <div class="contact-info">
          <p class="eyebrow">Say hello</p>
          <h2 class="display-h2">Let's start a <span>conversation.</span></h2>
          <!-- TODO_HUMMICO: Replace this intro line with your real brand voice if you like. -->
          <p class="body-text">
            Whether you're planning a thoughtful gift, dreaming up a custom box, or
            simply want to chat about tea we read every message ourselves and would
            be delighted to help.
          </p>

          <p class="contact-custom-note">Custom &amp; corporate orders welcome. Message us anytime.</p>

          <ul class="contact-list">
            <!-- Location -->
            <li class="contact-item">
              <span class="contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#225234" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span class="contact-text">
                <span class="contact-label">Where we are</span>
                <span class="contact-value">Houston, Texas</span>
              </span>
            </li>

            <!-- Email (real text, NOT a mailto link, so it isn't harvested) -->
            <li class="contact-item">
              <span class="contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#225234" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </span>
              <span class="contact-text">
                <span class="contact-label">Email us</span>
                <span class="contact-value">{EMAIL}</span>
              </span>
            </li>
          </ul>

          <!-- Socials -->
          <p class="contact-label" style="margin-top:6px;">Find us online</p>
          <div class="social-row">
            <a href={INSTAGRAM} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Hummico Designs on Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#225234" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="#225234" stroke="none"/>
              </svg>
            </a>
            <a href={ETSY} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Hummico Designs on Etsy">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#225234">
                <path d="M5 2h2.5v20H5V2zm3.5 0h8.8c.4 1.2.7 2.5.8 3.8h-.8C16.6 4.2 15.4 3 13 3H9.5v7H12c.5-1 1-2 1.5-2.5h.8v6h-.8C13 13 12.5 12 12 12H9.5v7H13c2.4 0 3.8-1.4 4.6-3h.8c-.2 1.5-.5 2.8-.9 4H5v-1h.5c1 0 1.5-.3 1.5-1V3.5C7 2.8 6.5 2.5 5.5 2.5H5V2h3.5z"/>
              </svg>
            </a>
            <a href={PINTEREST} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Hummico Designs on Pinterest">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#225234">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.852 0 1.265.64 1.265 1.408 0 .858-.546 2.14-.828 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.138-1.867 3.138-4.562 0-2.387-1.715-4.057-4.163-4.057-2.836 0-4.498 2.127-4.498 4.326 0 .856.33 1.775.741 2.276a.3.3 0 0 1 .069.284c-.076.313-.244.995-.277 1.134-.044.183-.146.222-.337.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- RIGHT: Web3Forms contact form -->
        <div class="contact-form-wrap">
          <form id="contact-form" class="contact-form" novalidate>
            <!-- TODO_HUMMICO: paste your real Web3Forms access key in place of YOUR_WEB3FORMS_KEY -->
            <input type="hidden" name="access_key" value="751bbde9-a623-46c8-85c3-fccb88cba6d5" />
            <input type="hidden" name="subject" value="New message from Hummico website" />
            <input type="hidden" name="from_name" value="Hummico Designs Website" />
            <!-- Honeypot spam trap (kept off-screen; real visitors leave it empty) -->
            <input type="checkbox" name="botcheck" class="botcheck" tabindex="-1" autocomplete="off" />

            <div class="field">
              <label for="cf-name">Name</label>
              <input id="cf-name" name="name" type="text" autocomplete="name" required placeholder="Your name" />
            </div>

            <div class="field">
              <label for="cf-email">Email</label>
              <input id="cf-email" name="email" type="email" autocomplete="email" required placeholder="you@example.com" />
            </div>

            <div class="field">
              <label for="cf-message">Message</label>
              <textarea id="cf-message" name="message" rows="5" required placeholder="Tell us what's on your mind…"></textarea>
            </div>

            <p class="form-reply-note">We usually reply within 1–2 business days.</p>

            <button type="submit" class="form-btn" id="cf-submit">
              <span class="btn-label">Send message</span>
            </button>

            <!-- Inline status messages (shown by JS, polite for screen readers) -->
            <p class="form-status form-status--success" id="cf-success" role="status" hidden>
              Thank you — we'll be in touch soon.
            </p>
            <p class="form-status form-status--error" id="cf-error" role="alert" hidden>
              Something went wrong. Please try again, or email us directly.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ 3. EMBEDDED MAP (Houston, city-level) ════════════════ -->
  <section class="section map-section" aria-label="Our location: Houston, Texas">
    <div class="container">
      <div class="map-head">
        <p class="eyebrow">Our corner of the world</p>
        <h2 class="display-h2">Crafted in <span>Houston, Texas.</span></h2>
      </div>
      <div class="map-frame">
        <!-- City-level Houston map (no specific street address). The embed URL needs no API key.
             TODO_HUMMICO: optional — swap for a custom-styled Google Maps embed if you prefer. -->
        <iframe
          title="Map of Houston, Texas"
          src="https://www.google.com/maps?q=Houston,+Texas&z=10&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ════════════════ 4. NEWSLETTER ════════════════ -->
  <!-- The shared <Newsletter /> component is rendered automatically by BaseLayout,
       directly above the shared <Footer />, so it already sits here above the footer. -->
</BaseLayout>

<style>
  /* ─────────── Shared type + layout helpers (match the other pages) ─────────── */
  .eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: #e491a6;
    margin-bottom: 16px;
  }
  .display-h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(2rem, 4.4vw, 3rem);
    color: #225234;
    line-height: 1.12;
    margin: 0;
  }
  .display-h2 span {
    font-style: italic;
    font-weight: 300;
    color: #e491a6;
  }
  .body-text {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: clamp(0.92rem, 1.4vw, 1.05rem);
    line-height: 1.9;
    color: #225234;
    opacity: 0.85;
    margin-top: 18px;
  }
  /* Friendly "custom & corporate orders" line in the contact info column */
  .contact-custom-note {
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    line-height: 1.6;
    color: #225234;
    margin: 20px 0 0;
    padding-left: 14px;
    border-left: 2px solid #e491a6;
  }
  /* Calm reply-time reassurance near the form's submit button */
  .form-reply-note {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: #225234;
    opacity: 0.7;
    margin: 0 0 14px;
  }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .section { background-color: #faf6f0; padding: 100px 0; }

  /* ─────────── 1. HERO ─────────── */
  .chero {
    position: relative;
    width: 100%;
    margin-top: 160px; /* clears the fixed topbar + transparent navbar, like the other pages */
    min-height: calc(70vh - 160px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .chero-bg {
    position: absolute;
    inset: 0;
    /* Solid brand-green fallback shows through if an image is missing (no broken-image gray). */
    background-color: #225234;
    /* TODO_HUMMICO: add the real Contact hero images to /public.
       Desktop: /hero-contact.jpg  ·  Mobile (<=768px): /hero-contact-mobile.jpg
       (desktop ~1920x1080 landscape; mobile a portrait crop). Mobile swap is in the media query below. */
    background-image: url('/hero-land.png');
    background-size: cover;
    background-position: center;
  }
  .chero-overlay {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
    width: 100%;
    min-height: calc(70vh - 160px);
    background: linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.34) 55%, rgba(0,0,0,0.30) 100%);
  }
  .chero-eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #faf6f0;
    font-size: clamp(0.6rem, 1.2vw, 0.78rem);
    margin-bottom: 20px;
  }
  .chero-headline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-style: italic;
    color: #ffffff;
    line-height: 1.08;
    font-size: clamp(2.6rem, 6.4vw, 5.6rem);
    margin-bottom: 10px;
    max-width: 900px;
  }
  .chero-headline span { font-style: normal; font-weight: 600; color: #f5e8d8; }
  .chero-sub {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    color: rgba(255,255,255,0.82);
    font-size: clamp(0.85rem, 1.5vw, 1.05rem);
    letter-spacing: 0.04em;
    margin-top: 16px;
    max-width: 520px;
    line-height: 1.8;
  }

  /* ─────────── 2. CONTACT INFO + FORM ─────────── */
  .contact-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 56px;
    align-items: stretch;
  }

  .contact-info { display: flex; flex-direction: column; }
  .contact-list {
    list-style: none;
    margin: 34px 0 30px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .contact-item { display: flex; align-items: center; gap: 16px; }
  .contact-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: #ffffff;
    border: 1px solid rgba(34, 82, 52, 0.1);
    box-shadow: 0 10px 26px rgba(34, 82, 52, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-text { display: flex; flex-direction: column; gap: 3px; }
  .contact-label {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.66rem;
    color: #e491a6;
  }
  .contact-value {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: #225234;
    word-break: break-word;
  }
  .social-row { display: flex; gap: 12px; margin-top: 12px; }
  .social-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: #ffffff;
    border: 1px solid rgba(34, 82, 52, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
  }
  .social-icon:hover {
    transform: translateY(-3px);
    background-color: #efe2cf;
    box-shadow: 0 12px 26px rgba(34, 82, 52, 0.12);
  }

  /* Form card */
  .contact-form-wrap {
    background-color: #ffffff;
    border: 1px solid rgba(34, 82, 52, 0.08);
    border-top: 3px solid #e491a6;
    border-radius: 22px;
    padding: clamp(28px, 4vw, 44px);
    box-shadow: 0 24px 60px rgba(34, 82, 52, 0.08);
  }
  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field label {
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: #225234;
  }
  .field input,
  .field textarea {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    color: #225234;
    background-color: #faf6f0;
    border: 1px solid rgba(34, 82, 52, 0.14);
    border-radius: 12px;
    padding: 14px 16px;
    width: 100%;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease;
  }
  .field textarea { resize: vertical; min-height: 130px; }
  .field input::placeholder,
  .field textarea::placeholder { color: rgba(34, 82, 52, 0.45); }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: #e491a6;
    background-color: #ffffff;
    box-shadow: 0 0 0 3px rgba(228, 145, 166, 0.16);
  }

  /* Honeypot — visually hidden but reachable to bots */
  .botcheck { position: absolute; left: -9999px; opacity: 0; height: 0; width: 0; }

  .form-btn {
    align-self: flex-start;
    margin-top: 4px;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: #faf6f0;
    background-color: #225234;
    border: none;
    border-radius: 50px;
    padding: 15px 40px;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
  }
  .form-btn:hover {
    background-color: #2d6b47;
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(34, 82, 52, 0.22);
  }
  .form-btn[disabled] { opacity: 0.65; cursor: progress; transform: none; box-shadow: none; }

  .form-status {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
    padding: 12px 16px;
    border-radius: 12px;
  }
  .form-status--success {
    color: #225234;
    background-color: rgba(34, 82, 52, 0.08);
    border: 1px solid rgba(34, 82, 52, 0.16);
  }
  .form-status--error {
    color: #9c4a5d;
    background-color: rgba(228, 145, 166, 0.12);
    border: 1px solid rgba(228, 145, 166, 0.4);
  }

  /* ─────────── 3. MAP ─────────── */
  .map-section { padding-top: 40px; }
  .map-head { text-align: center; margin-bottom: 40px; }
  .map-frame {
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid rgba(34, 82, 52, 0.1);
    box-shadow: 0 24px 60px rgba(34, 82, 52, 0.12);
    height: 440px;
    background-color: #efe2cf;
  }
  .map-frame iframe { display: block; width: 100%; height: 100%; }

  /* ─────────── Responsive (~mobile 400px) ─────────── */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 768px) {
    .section { padding: 70px 0; }
    .map-section { padding-top: 30px; }
    .chero { margin-top: 130px; min-height: calc(58vh - 130px); }
    .chero-overlay { min-height: calc(58vh - 130px); padding: 60px 22px; }
    /* Swap to the portrait Contact hero image on phones (matches the homepage pattern). */
    .chero-bg { background-image: url('/hero-mobile.png'); }
    .chero-eyebrow { letter-spacing: 0.22em; }
    .map-frame { height: 340px; }
  }
  @media (max-width: 560px) {
    .form-btn { align-self: stretch; text-align: center; }
    .map-frame { height: 300px; }
  }
</style>

<script>
  // Submit the contact form via Web3Forms (AJAX) — no page reload, inline status.
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('cf-success');
  const errorEl = document.getElementById('cf-error');
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const btnLabel = submitBtn?.querySelector('.btn-label');

  if (form && submitBtn && btnLabel) {
    const defaultLabel = btnLabel.textContent;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Use native validation for the required fields.
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      successEl?.setAttribute('hidden', '');
      errorEl?.setAttribute('hidden', '');
      submitBtn.disabled = true;
      btnLabel.textContent = 'Sending…';

      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await res.json();

        if (res.ok && result.success) {
          form.reset();
          successEl?.removeAttribute('hidden');
        } else {
          errorEl?.removeAttribute('hidden');
        }
      } catch {
        errorEl?.removeAttribute('hidden');
      } finally {
        submitBtn.disabled = false;
        btnLabel.textContent = defaultLabel;
      }
    });
  }
</script>

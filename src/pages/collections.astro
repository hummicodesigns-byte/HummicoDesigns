    category: 'Organic Herbal Tea Set',
  },
  {
    name: 'TODO_HUMMICO — Thinking of You Set',
    description: 'A heartfelt little gift of warm sips and small comforts — a quiet way to say someone matters to you.',
    price: '$18.36',

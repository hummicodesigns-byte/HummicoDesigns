    description: 'A heartfelt little gift of warm sips and small comforts — a quiet way to say someone matters to you.',
    price: '$26.36',
    etsyLink: 'https://www.etsy.com/listing/TODO_HUMMICO',
    image: 'collect7.jpg',
    category: 'Tea Bag Bundle Gift Box',
  },
  {
    name: 'TODO_HUMMICO — Thinking of You Set',
    description: 'A heartfelt little gift of warm sips and small comforts — a quiet way to say someone matters to you.',
    price: '$34.36',
    etsyLink: 'https://www.etsy.com/listing/TODO_HUMMICO',
    image: 'collect8.jpg',
    category: 'Coffee Tea Bundle',
  },
  {
    name: 'TODO_HUMMICO — Thinking of You Set',
    description: 'A heartfelt little gift of warm sips and small comforts — a quiet way to say someone matters to you.',
    price: '$31.16',
    etsyLink: 'https://www.etsy.com/listing/TODO_HUMMICO',
    image: 'collect9.jpg',
    category: 'Tea Bag Bundle Gift Box',
  },

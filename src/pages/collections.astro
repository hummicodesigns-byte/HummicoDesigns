// (names, descriptions, prices and Etsy URLs are all stand-ins). Revisit when real product
// data lands. No aggregateRating/review is emitted yet — adding fake ratings risks a Google
// manual penalty, so those will be added only once real Etsy reviews are in.
const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Collections', path: '/collections/' },
  ]),
  ...bestSellers.map((p) =>
    productSchema({
      name: p.name,
      description: p.description,
      image: p.image,
      url: p.etsyLink,
      price: p.price,
    })
  ),
];
---

<BaseLayout
  title="Tea Ritual Boxes & Wellness Gift Sets — Hummico Collections"
  description="Explore Hummico's organic herbal tea boxes, wellness gifts, coffee retreat sets and self-care bundles — hand-packed in Houston, TX and available to shop on Etsy."
  schemas={schemas}
>
  <!-- ════════════════ 1. HERO ════════════════ -->
  <!-- TODO_HUMMICO: Replace the placeholder background on .chero-bg with the real
       Collections hero image (calming/lifestyle, ~1920x1080). Keep the dark overlay
       gradient in .chero-overlay for text legibility — same treatment as home/about. -->
  <section class="chero" aria-label="Shop the Hummico collections">
    <div class="chero-bg" data-placeholder="collections-hero-image"></div>
    <div class="chero-overlay">
      <p class="chero-eyebrow">Hand-curated · Made to be gifted</p>
      <h1 class="chero-headline">Shop the<br /><span>collections.</span></h1>
      <p class="chero-sub">
        Herbal tea boxes, wellness gifts and quiet luxuries — each one curated by
        hand and wrapped with care, ready to find its person.
      </p>
    </div>
  </section>

  <!-- ════════════════ 2. BEST SELLERS ════════════════ -->
  <section id="best-sellers" class="section bestsellers" aria-label="Best sellers">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Most loved</p>
        <h2 class="display-h2">Our <span>best sellers.</span></h2>
        <p class="section-lead">The boxes our customers reach for again and again.</p>
      </div>

      <!-- Reusable product-card grid (4 across on desktop). -->
      <div class="card-grid card-grid--4" data-reveal-group>
        {bestSellers.map((p) => (
          <article class="product-card" data-reveal data-tags={p.tags.join(' ')}>
            <div class="product-card-media">
              {p.image
                ? <img src={p.image} alt={p.name} class="product-card-img" loading="lazy" />
                : <div class="product-card-ph img-placeholder"><span>TODO_HUMMICO<br />product image</span></div>}
            </div>
            <div class="product-card-body">
              <h3 class="product-card-name">{p.name}</h3>
              <p class="product-card-desc">{p.description}</p>
              <div class="product-card-foot">
                <span class="product-card-price">{p.price}</span>
                <a
                  href={p.etsyLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="etsy-btn"
                >Shop on Etsy</a>
              </div>
            </div>
          </article>
        ))}
      </div>
      <p class="etsy-note">You'll complete your order securely on Etsy.</p>
    </div>
  </section>

  <!-- ════════════════ FILTER CHIPS (Shop by occasion) ════════════════ -->
  <!-- Filters product cards across Best Sellers, Our Collections AND Featured Gifts. -->
  <section class="filter-bar" aria-label="Filter collections by occasion">
    <div class="container">
      <p class="eyebrow filter-eyebrow">Shop by occasion</p>
      <div class="chips" role="tablist" aria-label="Shop by occasion">
        {chips.map((chip, i) => (
          <button
            class="chip"
            type="button"
            role="tab"
            aria-pressed={i === 0 ? 'true' : 'false'}
            data-filter={chip.tags.join(' ')}
          >{chip.label}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════ 3. OUR COLLECTIONS (grid + filters) ════════════════ -->
  <section id="our-collections" class="section collections-grid" aria-label="Our collections">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Browse everything</p>
        <h2 class="display-h2">Our <span>collections.</span></h2>
        <p class="section-lead">Find the right little ritual for the right person.</p>
      </div>

      <div class="card-grid card-grid--3" data-reveal-group>
        {collectionProducts.map((p) => (
          <article class="product-card" data-reveal data-tags={p.tags.join(' ')}>
            <div class="product-card-media">
              {p.image
                ? <img src={p.image} alt={p.name} class="product-card-img" loading="lazy" />
                : <div class="product-card-ph img-placeholder"><span>TODO_HUMMICO<br />product image</span></div>}
              <span class="product-card-chip">{p.category}</span>
            </div>
            <div class="product-card-body">
              <h3 class="product-card-name">{p.name}</h3>
              <p class="product-card-desc">{p.description}</p>
              <div class="product-card-foot">
                <span class="product-card-price">{p.price}</span>
                <a
                  href={p.etsyLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="etsy-btn"
                >Shop on Etsy</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Shown in place of the grid when a filter matches no Our Collections products -->
      <div class="filter-empty" data-filter-empty hidden>
        <p>Nothing in this collection yet — but new boxes are added regularly. Try another filter or check back soon.</p>
      </div>

      <p class="etsy-note">You'll complete your order securely on Etsy.</p>
    </div>
  </section>

  <!-- ════════════════ 4. FEATURED GIFTS (GSAP horizontal scroll-stack) ════════════════ -->
  <!-- Desktop (>768px): the section pins and each card slides in from the RIGHT,
       stacking/overlaying the previous one (GSAP ScrollTrigger).
       Mobile (<=768px): NO scroll-hijacking — a native swipeable, scroll-snap carousel.
       All card text is real HTML; GSAP only animates the existing cards. -->
  <section id="featured-gifts" class="featured" aria-label="Featured gifts">
    <div class="container">
      <div class="section-head section-head--light">
        <p class="eyebrow">Worth the spotlight</p>
        <h2 class="display-h2">Featured <span>gifts.</span></h2>
        <p class="section-lead">A closer look at the pieces we are proudest of.</p>
        <p class="etsy-note etsy-note--light">You'll complete your order securely on Etsy.</p>
      </div>
    </div>

    <div class="featured-viewport" data-featured>
      <div class="featured-stack" data-featured-stack>
        {featured.map((p, i) => (
          <article class="featured-card" data-featured-card data-tags={p.tags.join(' ')}>
            <!-- LEFT: light/white info panel (noticeably lighter than the off-white bg) -->
            <div class="featured-panel">
              <span class="featured-index">{String(i + 1).padStart(2, '0')} / {String(featured.length).padStart(2, '0')}</span>
              <h3 class="featured-name">{p.name}</h3>
              <p class="featured-desc">{p.description}</p>
              <div class="featured-foot">
                <span class="featured-price">{p.price}</span>
                <a
                  href={p.etsyLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="etsy-btn"
                >Shop on Etsy</a>
              </div>
            </div>
            <!-- RIGHT: product image -->
            <div class="featured-media">
              {p.image
                ? <img src={p.image} alt={p.name} class="featured-img" loading="lazy" />
                : <div class="featured-ph img-placeholder"><span>TODO_HUMMICO<br />product image</span></div>}
            </div>
          </article>
        ))}
      </div>
      <!-- Scroll/swipe hint -->
      <p class="featured-hint" data-featured-hint>
        <span class="featured-hint-desktop">Scroll to explore</span>
        <span class="featured-hint-mobile">Swipe to explore →</span>
      </p>
    </div>
  </section>

  <!-- ════════════════ SEALED-FRESHNESS STRIP (full-width quality band) ════════════════ -->
  <!-- TODO_HUMMICO: Replace /sealed-strip-bg.jpg with client-provided image (close-up of sealed tea jars or similar) -->
  <section class="sealed-strip" aria-label="Quality you can trust">
    <div class="sealed-strip-overlay"></div>
    <div class="sealed-strip-content">
    </div>
  </section>

  <!-- ════════════════ 5. MASONRY IMAGERY ════════════════ -->
  <section class="section masonry-section" aria-label="From the Hummico studio">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">In the wild</p>
        <h2 class="display-h2">From the <span>studio.</span></h2>
        <p class="section-lead">Little moments of calm, captured.</p>
      </div>

      <!-- TODO_HUMMICO: Replace each tile background with a real photo (see `gallery` data). -->
      <div class="masonry" data-reveal-group>
        {gallery.map((g) => (
          <figure class={`masonry-item masonry-item--span${g.span}`} data-reveal>
            {g.image
              ? <img src={g.image} alt={g.caption} class="masonry-img" loading="lazy" />
              : <div class="masonry-ph img-placeholder"><span>TODO_HUMMICO image</span></div>}
            <figcaption class="masonry-cap">{g.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════ 6. NEWSLETTER ════════════════ -->
  <!-- The shared <Newsletter /> component is rendered automatically by BaseLayout,
       directly above the shared <Footer /> — so it already sits here, above the footer.
       (No need to import it again; doing so would render two newsletters.) -->
</BaseLayout>

<style>
  /* ─────────── Filter chips (Shop by occasion) ─────────── */
  .filter-bar {
    background-color: #faf6f0;
    padding: 56px 0 0;
  }
  .filter-eyebrow {
    text-align: center;
    margin-bottom: 18px;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
  }
  .chip {
    flex: 0 0 auto;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    font-size: 0.84rem;
    letter-spacing: 0.04em;
    padding: 11px 22px;
    border-radius: 999px;
    border: 1px solid #225234;
    background-color: #faf6f0;
    color: #225234;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.15s ease;
  }
  .chip:hover { background-color: rgba(34, 82, 52, 0.08); }
  .chip[aria-pressed='true'] {
    background-color: #225234;
    color: #faf6f0;
  }
  .chip:focus-visible { outline: 2px solid #e491a6; outline-offset: 2px; }

  /* Empty state when a filter matches nothing */
  .filter-empty {
    text-align: center;
    padding: 80px 20px;
  }
  .filter-empty p {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1.5;
    color: #225234;
    opacity: 0.82;
    max-width: 44ch;
    margin: 0 auto;
  }

  /* Mobile: chips scroll horizontally on one line (no wrap), scrollbar hidden but functional */
  @media (max-width: 600px) {
    .chips {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x proximity;
      scrollbar-width: none; /* Firefox */
    }
    .chips::-webkit-scrollbar { display: none; } /* Chrome/Safari */

    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.68rem;
    color: rgba(250, 246, 240, 0.7);
  }
  .featured-hint-desktop { display: none; }
  .featured-hint-mobile { display: inline; }

  /* Desktop (>768px) WITH JS + motion (.js-featured, added by the script): cards become
     wide rectangles (image RIGHT, light panel LEFT) and are absolutely stacked at the
     SAME centered position inside a pinned, overflow-clipped frame. An incoming card
     waits exactly one card-width to the right (clipped → invisible) and slides in to
     FULLY overlay the current one. Without JS / reduced motion the carousel above is
     kept as a graceful fallback. */
  @media (min-width: 769px) {
    .featured-viewport.is-pinned {
      position: relative;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 20px;
      /* Fill the screen and vertically center the stack inside it. While pinned
         (from top top) the wrapper is locked to the viewport and the stack sits
         centered within it, so the cards stay VERTICALLY CENTERED for the whole
         horizontal scroll — only x ever changes, no upward drift. */
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    /* Hint pinned to the bottom so it never affects the stack's vertical centering. */
    .featured-viewport.is-pinned .featured-hint {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 28px;
      margin: 0;
    }
    .featured-viewport.is-pinned .featured-stack {
      position: relative;
      display: block;
      overflow: hidden;                 /* clips any card not yet in its centered spot */
      height: 62vh;
      min-height: 460px;
      padding: 0;
      border-radius: 24px;
      box-shadow: 0 30px 70px rgba(0, 0, 0, 0.28); /* shadow on the frame so it isn't clipped */
    }
    .featured-viewport.is-pinned .featured-card {
      position: absolute;
      inset: 0;
      flex-direction: row;
      flex: initial;
      border-radius: 0;                 /* rounded corners handled by the clipping frame */
      box-shadow: none;
    }
    .featured-viewport.is-pinned .featured-panel { flex: 0 0 45%; padding: clamp(36px, 4vw, 60px); }
    .featured-viewport.is-pinned .featured-media { flex: 1; min-height: 0; }
    .featured-viewport.is-pinned .featured-ph { height: 100%; min-height: 0; }
    .featured-viewport.is-pinned .featured-hint-desktop { display: inline; }
    .featured-viewport.is-pinned .featured-hint-mobile { display: none; }
  }

  /* ─────────── 5. MASONRY ─────────── */
  .masonry {
    column-count: 3;
    column-gap: 20px;
  }
  .masonry-item {
    position: relative;
    break-inside: avoid;
    margin: 0 0 20px;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 16px 44px rgba(34, 82, 52, 0.1);
  }
  .masonry-img,
  .masonry-ph {
    width: 100%;
    display: block;
  }
  .masonry-item--span1 .masonry-ph { aspect-ratio: 4 / 3; }
  .masonry-item--span2 .masonry-ph { aspect-ratio: 3 / 4; }
  .masonry-ph {
    flex-direction: column;
    text-align: center;
    font-family: 'Jost', sans-serif;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.62rem;
    opacity: 0.6;
  }
  .masonry-cap {
    position: absolute;
    left: 16px;
    bottom: 14px;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    color: #faf6f0;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }

  /* Reveal animation note: the hidden start-state is set in JS via gsap.from(), so
     content stays fully visible without JS and there is no scoped-CSS dependency. */

  /* ─────────── Responsive ─────────── */
  @media (max-width: 1024px) {
    .card-grid--4 { grid-template-columns: repeat(2, 1fr); }
    .card-grid--3 { grid-template-columns: repeat(2, 1fr); }
    .masonry { column-count: 2; }
  }
  @media (max-width: 768px) {
    .section { padding: 70px 0; }
    .featured { padding: 70px 0; }
    .section-head { margin-bottom: 40px; }
    .chero { margin-top: 130px; min-height: calc(64vh - 130px); }
    .chero-overlay { min-height: calc(64vh - 130px); padding: 64px 22px; }
    /* Swap to the portrait Collections hero image on phones (matches the homepage pattern). */
    .chero-bg { background-image: url('/hero-3mobile.png'); }
    .chero-eyebrow { letter-spacing: 0.22em; }

    /* Mobile cards: IMAGE on top, text/price/Etsy below (standard product-card
       stacking). order:-1 lifts the media above the panel in the column flow, and
       a fixed height keeps the image from becoming a huge empty block. */
    .featured-media { order: -1; min-height: 0; height: 220px; }
    .featured-ph { min-height: 0; height: 220px; }
  }
  @media (max-width: 560px) {
    .card-grid--4,
    .card-grid--3 { grid-template-columns: 1fr; }
    .masonry { column-count: 1; }
    .product-card-name { font-size: 1.3rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card,
    .product-card-img,
    .etsy-btn { transition: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── 4. FEATURED GIFTS — horizontal scroll-stack (desktop only) ──────────────
  // Mobile keeps the native scroll-snap carousel from CSS (no JS, no hijack).
  const viewport = document.querySelector<HTMLElement>('[data-featured]');
  const stack = document.querySelector<HTMLElement>('[data-featured-stack]');

  if (viewport && stack && !reduce) {
    // Enable the desktop pinned-stack layout. The class goes on an in-component element
    // (not <html>) so Astro's scoped styles match it; no-JS / reduced-motion users keep
    // the plain swipe carousel as a fallback.
    viewport.classList.add('is-pinned');

    const cards = gsap.utils.toArray<HTMLElement>('[data-featured-card]', stack);
    const mm = gsap.matchMedia();

    mm.add('(min-width: 769px)', () => {
      // Every card sits at the SAME centered spot (inset:0). Later cards start exactly
      // one card-width to the right (xPercent:100) — that's right at the clipped frame's
      // edge, so nothing peeks — and ascend in z-index so each new arrival layers ABOVE
      // the previous one.
      gsap.set(cards, { zIndex: (i: number) => i + 1, xPercent: 0 });
      gsap.set(cards.slice(1), { xPercent: 100 });

      // Pin from 'top top': the viewport wrapper is 100vh, so once its top reaches the
      // top of the screen it locks in place filling the viewport, and the stack stays
      // flex-centered within it for the entire scrub. This keeps the cards vertically
      // centered the whole time (no upward drift) — only x animates below.
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: viewport,
          start: 'top top',
          end: () => `+=${(cards.length - 1) * window.innerHeight * 0.9}`,
          pin: true,
          scrub: 1,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        },
      });

      // Each later card slides in from the right to fully overlay the previous one.
      cards.forEach((card, i) => {
        if (i === 0) return;
        tl.to(card, { xPercent: 0, ease: 'none' }, i - 1);
      });

      return () => gsap.set(cards, { clearProps: 'transform,zIndex' });
    });
  }

  // ── Gentle scroll reveals for product cards + masonry (enhancement only) ─────
  // Content is real HTML and fully visible without JS; we only add the class that
  // hides-then-reveals once we know GSAP is running and motion is allowed.
  if (!reduce) {
    gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
      gsap.from(el, {
        opacity: 0,
        y: 28,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 88%' },
      });
    });
  }
</script>

<script>
  import ScrollTrigger from 'gsap/ScrollTrigger';

  // ── Filter chips (Shop by occasion) ────────────────────────────────────────
  // Filters ONLY the Our Collections grid. Best Sellers and Featured Gifts always show
  // all of their products. A product matches a chip if its data-tags contains ANY of the
  // chip's tags. "All" has an empty data-filter and matches everything.
  const chipEls = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip[data-filter]'));
  const ourCollections = document.getElementById('our-collections');
  // Scope the cards, grid, and empty-state to the Our Collections section only.
  const cards = ourCollections
    ? Array.from(ourCollections.querySelectorAll<HTMLElement>('[data-tags]'))
    : [];
  const grid = ourCollections?.querySelector<HTMLElement>('.card-grid') ?? null;
  const emptyState = ourCollections?.querySelector<HTMLElement>('[data-filter-empty]') ?? null;

  function applyFilter(filterStr: string) {
    const wanted = filterStr.trim() ? filterStr.trim().split(/\s+/) : [];
    let anyVisible = false;

    cards.forEach((card) => {
      const cardTags = (card.getAttribute('data-tags') || '').split(/\s+/).filter(Boolean);
      const show = wanted.length === 0 || wanted.some((t) => cardTags.includes(t));
      card.style.display = show ? '' : 'none';
      if (show) anyVisible = true;
    });

    // Swap the grid for the empty-state message when nothing matches (heading stays).
    if (grid) grid.style.display = anyVisible ? '' : 'none';
    if (emptyState) emptyState.hidden = anyVisible;
  }

  chipEls.forEach((chip) => {
    chip.addEventListener('click', () => {
      chipEls.forEach((c) => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      applyFilter(chip.getAttribute('data-filter') || '');

      // Filtering shows/hides cards, which changes the Our Collections height and shifts
      // everything below it. ScrollTrigger caches layout positions on init, so the pinned
      // Featured Gifts stack just below would trigger at stale scroll offsets. Let the
      // display:none/'' reflow settle a tick, then recalculate all trigger positions.
      setTimeout(() => {
        if (typeof ScrollTrigger !== 'undefined') ScrollTrigger.refresh();
      }, 50);
    });
  });
</script>

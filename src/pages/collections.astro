---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema, productSchema } from '../lib/seo';

// ─────────────────────────────────────────────────────────────────────────────
// COLLECTIONS PAGE — placeholder data
//
// Everything below is REAL static content rendered into the HTML at build time
// (good for SEO). GSAP only animates the existing DOM; it never injects text.

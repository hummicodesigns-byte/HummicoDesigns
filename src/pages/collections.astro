    image: 'collect12.webp',
    category: 'Tea Refill Set',
  },

];

// TODO_HUMMICO: Replace these 4 placeholder featured products (each shows a light
// info panel on the left and a product photo on the right).
const featured = [
  {
    name: 'TODO_HUMMICO — Signature Tea Ritual',
    description: 'Our most-loved box, made larger and lovelier — a complete slow-living ritual of hand-blended teas and quiet comforts, presented to feel like an occasion in itself.',
    price: '$00.00',
    etsyLink: 'https://www.etsy.com/listing/TODO_HUMMICO',
    image: '',
  },
  {
    name: 'TODO_HUMMICO — The Calm Collection',

  { label: 'All', tags: [] },
  { label: 'For Her', tags: ['for-her'] },
  { label: 'For Him', tags: ['for-him'] },
  { label: 'Self-care & Relaxation', tags: ['self-care', 'relaxation', 'spa', 'wellness'] },
  { label: 'Birthday', tags: ['birthday'] },
  { label: "Mother's Day", tags: ['mothers-day'] },

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Philosophy from '../components/Philosophy.astro';
import CollectionsTeaser from '../components/CollectionsTeaser.astro';
import OurGuarantee from '../components/OurGuarantee.astro';
import BusinessCard from '../components/BusinessCard.astro';
import InstagramReels from '../components/InstagramReels.astro';
import Reviews from '../components/Reviews.astro';
import { localBusinessSchema } from '../lib/seo';
---

<BaseLayout
  title="Hummico Designs — Organic Herbal Tea Gift Boxes in Houston, TX"
  description="Sister-owned Hummico Designs hand-packs organic herbal tea gift boxes and wellness sets in Houston, TX — calming rituals and thoughtful gifting, shop on Etsy."
  appendSiteName={false}
  schemas={[localBusinessSchema]}
>
  <Hero />
  <About />
  <Philosophy />
  <CollectionsTeaser />
  <OurGuarantee />
  <BusinessCard />
  <Reviews />
  <InstagramReels />
</BaseLayout>

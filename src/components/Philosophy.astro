---
// Short, calming teaser blurbs that funnel to the future blog.
// TODO_HUMMICO: Refine this copy to match your real blog posts, and (once the blog
// exists) point each "Read more" at its specific article instead of the /blog index.
//
// TODO_HUMMICO: Replace each card's `image` below with a real photo (calming/lifestyle,
// portrait-ish ~1000x1300). These are temporary stand-ins pulled from existing assets.
const blurbs = [
  {
    num: '01',
    title: 'The ritual of slowing down',
    body: 'Steeping a cup is a small permission to pause. We blend for calm mornings and unhurried evenings the quiet moments that put you back together.',
    image: '/philo1.jpg', // TODO_HUMMICO: swap for real "ritual / slow morning" photo
    link: '/blog/how-to-brew-loose-leaf-herbal-tea',
  },
  {
    num: '02',
    title: 'Herbs chosen with intention',
    body: 'Chamomile to soften the day’s edges, peppermint to clear the mind, lavender to settle it. Gentle by nature, and chosen with real care.',
    image: '/philo3.jpg', // TODO_HUMMICO: swap for real "herbs / ingredients" photo
    link: '/blog/calming-herbal-teas',
  },
  {
    num: '03',
    title: 'Care, as a love language',
    body: 'Every box is a deliberate act of being seen , wellness you can hold, wrapped to feel as good to give as it is to receive.',
    image: '/stress-relief-gift.jpg', // TODO_HUMMICO: swap for real "gifting / care" photo
    link: '/blog/whats-inside-a-hummico-tea-gift-box',
  },
];
---

<section class="philosophy" aria-label="Our philosophy" data-philosophy>
  <div class="philosophy-inner">
    <!-- Section heading — real static HTML, stays above the cards -->
    <div class="philosophy-head">
      <p class="philosophy-eyebrow">Our philosophy</p>
      <h2 class="philosophy-title">Wellness, <span>made quietly.</span></h2>
      <p class="philosophy-lede">
        A little on why we do this and what a Hummico ritual feels like.
      </p>
    </div>

    <!-- Single-card carousel: every card is real HTML; inactive ones are clipped by the
         viewport (overflow:hidden) and the track is moved with translateX. JS only switches
         which one is shown (arrows + dots + finger swipe); it never injects text. -->
    <div class="philosophy-carousel" data-philosophy-carousel>
      <button class="philosophy-arrow prev" data-prev type="button" aria-label="Previous card">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>

      <div class="philosophy-viewport" data-philosophy-viewport>
        <div class="philosophy-track" data-philosophy-track>
          {blurbs.map((blurb) => (
            <div class="philosophy-slide">
              <article class="pcard">
                <div class="pcard-bg" style={`background-image:url('${blurb.image}')`}></div>
                <div class="pcard-overlay"></div>
                <div class="pcard-content">
                  <span class="pcard-num">{blurb.num}</span>
                  <h3 class="pcard-title">{blurb.title}</h3>
                  <p class="pcard-body">{blurb.body}</p>
                  <a href={blurb.link} class="pcard-readmore">
                    Read more
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </div>
              </article>
            </div>
          ))}
        </div>
      </div>

      <button class="philosophy-arrow next" data-next type="button" aria-label="Next card">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <!-- Position dots (active dot is highlighted; click to jump) -->
    <div class="philosophy-dots" data-philosophy-dots>
      {blurbs.map((_, i) => (
        <button class="philosophy-dot" data-dot type="button" aria-label={`Go to card ${i + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<style>
  .philosophy {
    background-color: #faf6f0;
    position: relative;
    overflow: hidden;
  }
  .philosophy-inner {
    max-width: 1200px; /* room for the wider landscape cards; caps on ultra-wide screens */
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .philosophy-head {
    text-align: center;
    margin-bottom: 50px;
    padding: 0 24px;
  }
  .philosophy-eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: #e491a6;
    margin-bottom: 16px;
  }
  .philosophy-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(2rem, 4.4vw, 3rem);
    color: #225234;
    line-height: 1.12;
  }
  .philosophy-title span {
    font-style: italic;
    font-weight: 300;
    color: #e491a6;
  }
  .philosophy-lede {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: clamp(0.9rem, 1.4vw, 1rem);
    color: #225234;
    opacity: 0.7;
    margin-top: 16px;
    letter-spacing: 0.02em;
  }

  /* ── Carousel: one card centered, arrows flank it (mirrors Reviews) ──
     Desktop card is landscape (~780×480). The 80px side padding = arrow (52px) + ~28px
     gap, so each arrow sits just outside the card edge, vertically centered. */
  .philosophy-carousel {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
  }
  .philosophy-viewport {
    overflow: hidden;
  }
  .philosophy-track {
    display: flex;
    flex-wrap: nowrap;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  .philosophy-slide {
    flex: 0 0 100%;
    min-width: 100%;
    display: flex;
    justify-content: center;
    padding: 6px 4px;
  }

  /* Card design — visual styling unchanged; dimensions are landscape on desktop.
     Width fills the slide (driven by the carousel padding above), height is fixed. */
  .pcard {
    position: relative;
    width: 100%;
    height: 550px;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 26px 60px rgba(34, 82, 52, 0.18);
    isolation: isolate;
  }
  .pcard-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .pcard:hover .pcard-bg {
    transform: scale(1.1);
  }
  .pcard-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(20, 46, 30, 0.92) 0%,
      rgba(28, 64, 41, 0.55) 42%,
      rgba(34, 82, 52, 0.12) 100%
    );
  }
  .pcard-content {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    color: #faf6f0;
  }
  .pcard-num {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.2em;
    font-size: 0.78rem;
    color: #faf6f0;
    margin-bottom: 18px;
  }
  .pcard-title {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 600;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    line-height: 1.1;
    color: #ffffff;
    margin-bottom: 16px;
    max-width: 22ch;
  }
  .pcard-body {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: clamp(0.92rem, 1.1vw, 1.02rem);
    line-height: 1.75;
    color: rgba(250, 246, 240, 0.86);
    margin-bottom: 26px;
    max-width: 42ch;
  }
  .pcard-readmore {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.76rem;
    color: #ffffff;
    text-decoration: none;
    transition: gap 0.25s ease, color 0.25s ease;
  }
  .pcard-readmore svg { transition: transform 0.25s ease; }
  .pcard-readmore:hover { color: #e491a6; gap: 13px; }

  /* Arrows — same style as Reviews */
  .philosophy-arrow {
    position: absolute;
    top: 50%;
    margin-top: -26px;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: none;
    background-color: #225234;
    color: #faf6f0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 26px rgba(34, 82, 52, 0.22);
    transition: background-color 0.25s ease, transform 0.2s ease;
    z-index: 3;
  }
  .philosophy-arrow.prev { left: 0; }
  .philosophy-arrow.next { right: 0; }
  .philosophy-arrow:hover { background-color: #2d6b47; transform: scale(1.07); }

  /* Position dots */
  .philosophy-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 34px;
  }
  .philosophy-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background-color: rgba(34, 82, 52, 0.22);
    cursor: pointer;
    transition: background-color 0.25s ease, transform 0.25s ease;
  }
  .philosophy-dot:hover { background-color: rgba(34, 82, 52, 0.4); }
  .philosophy-dot[aria-current='true'] {
    background-color: #e491a6;
    transform: scale(1.25);
  }

  /* ── Tablet (600–899px): proportionally smaller landscape card (~540×380) ── */
  @media (min-width: 600px) and (max-width: 899px) {
    .philosophy-carousel { padding: 0 64px; }
    .pcard { height: 380px; }
  }

  /* ── Mobile (<=599px): one card fills the screen; arrows straddle its L/R edges ── */
  @media (max-width: 599px) {
    .philosophy { padding: 70px 20px; }
    .philosophy-head { margin-bottom: 40px; }
    .philosophy-carousel {
      padding: 0; /* no gutters; the slide inset makes room for the overlapping arrows */
    }
    .philosophy-slide {
      padding: 6px 26px; /* insets the card so each arrow sits half-on / half-off its edge */
    }
    .pcard {
      height: 70vh;
      max-height: 560px;
    }
    .philosophy-arrow {
      top: 50%;
      margin-top: -26px;
      width: 52px;
      height: 52px;
    }
    .philosophy-arrow.prev { left: 0; right: auto; }
    .philosophy-arrow.next { right: 0; left: auto; }
  }
</style>

<script>
  // Philosophy — single-card arrow / dot / swipe carousel.
  // Replaces the previous GSAP ScrollTrigger horizontal scroll-stack. Scoped to THIS
  // carousel so it never grabs another section's track (Reviews uses its own data-* hooks).
  const root = document.querySelector<HTMLElement>('[data-philosophy-carousel]');
  const track = root?.querySelector<HTMLElement>('[data-philosophy-track]');
  const viewport = root?.querySelector<HTMLElement>('[data-philosophy-viewport]');
  const prev = root?.querySelector<HTMLElement>('[data-prev]');
  const next = root?.querySelector<HTMLElement>('[data-next]');
  const dots = Array.from(
    document.querySelectorAll<HTMLElement>('[data-philosophy-dots] [data-dot]')
  );

  if (track && viewport && prev && next) {
    const count = track.children.length;
    let index = 0;

    const go = (i: number) => {
      index = ((i % count) + count) % count; // wrap/loop both ways
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, d) => dot.setAttribute('aria-current', d === index ? 'true' : 'false'));
    };

    prev.addEventListener('click', () => go(index - 1));
    next.addEventListener('click', () => go(index + 1));
    dots.forEach((dot, d) => dot.addEventListener('click', () => go(d)));

    // Finger swipe on mobile
    let startX = 0;
    let dragging = false;
    viewport.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      dragging = true;
    }, { passive: true });
    viewport.addEventListener('touchend', (e) => {
      if (!dragging) return;
      dragging = false;
      const delta = e.changedTouches[0].clientX - startX;
      if (Math.abs(delta) > 40) go(delta < 0 ? index + 1 : index - 1);
    });

    go(0);
  }
</script>

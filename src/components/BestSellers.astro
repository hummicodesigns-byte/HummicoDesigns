---
const bestSellers = [
  {
    id: 1,
    name: 'Herbal Tea Lover Box',
    price: '$29.93',
    description: 'Our signature wellness box with teas, self-care items, and calming goodies.',
    etsyLink: 'https://www.etsy.com/listing/4492643744/curated-tea-gift-set-with-amber-scented?sr_prefetch=1&pf_from=shop_home&ref=shop_home_active_12&crt=1&logging_key=5e020f4e893797c131656717138e14d0cda5eac1%3A4492643744',
    image: '/herbalbest.avif',
  },
  {
    id: 2,
    name: 'Lavender Coffee Retreat Box',
    price: '$46.93',
    description: 'Curated selection of premium herbal teas for relaxation and wellness.',
    etsyLink: 'https://www.etsy.com/listing/4506389580/lavender-coffee-retreat-box-goat-milk?sr_prefetch=1&pf_from=shop_home&ref=shop_home_active_4&pro=1&logging_key=7cda8d92967887e1613294ec046a6eb21030f53f%3A4506389580',
    image: '/herbalbest2.avif',
  },
  {
    id: 3,
    name: 'Luxury Herbal Tea Box (Honey Sticks)',
    price: '$23.94',
    description: 'Pamper yourself with luxurious self-care products and wellness powders.',
    etsyLink: 'https://www.etsy.com/listing/4510283393/luxury-herbal-tea-box-self-care-box?sr_prefetch=1&pf_from=shop_home&ref=shop_home_active_2&pro=1&logging_key=3ecf02f09aeeeaff13d0505db8168ec6f170d693%3A4510283393',
    image: '/herbal2.avif',
  },
];
---

<section id="products" style="padding:60px 20px;background-color:#faf6f0;position:relative;overflow:hidden;">
  <!-- Decorative Elements -->
  <div style="position:absolute;top:5%;right:2%;opacity:0.1;transform:rotate(20deg);">
    <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
      <circle cx="50" cy="50" r="45" stroke="#225234" stroke-width="1" fill="none" />
      <circle cx="50" cy="50" r="30" stroke="#225234" stroke-width="1" fill="none" />
    </svg>
  </div>
  <div style="position:absolute;bottom:10%;left:3%;opacity:0.1;">
    <svg width="80" height="120" viewBox="0 0 80 120" fill="none">
      <path d="M40 10 L60 40 L40 110 L20 40 Z" stroke="#225234" stroke-width="1" fill="none" />
    </svg>
  </div>

  <div style="max-width:1200px;margin:0 auto;">
    <!-- Section Header -->
    <div style="text-align:center;margin-bottom:60px;">
      <h2 style="font-size:2.5rem;font-weight:700;color:#225234;margin-bottom:15px;">Best Sellers</h2>
      <p style="font-size:1.1rem;color:#e491a6;font-weight:500;">Our most loved wellness creations</p>
    </div>

    <!-- Products Grid - Alternating Layout -->
    <div style="display:flex;flex-direction:column;gap:60px;">
      {bestSellers.map((product, index) => (
        <div
          class="product-row"
          style={`display:grid;grid-template-columns:1fr 1fr;direction:${index % 2 !== 0 ? 'rtl' : 'ltr'};gap:60px;align-items:center;`}
        >
          <!-- Image -->
          <div
            class={`product-image ${index % 2 !== 0 ? 'order-2' : 'order-1'}`}
            style="border-radius:20px;overflow:hidden;box-shadow:0 20px 50px rgba(34, 82, 52, 0.15);position:relative;direction:ltr;"
          >
            <img src={product.image} alt={product.name} style="width:100%;height:400px;object-fit:cover;display:block;" />
            <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(135deg, rgba(34, 82, 52, 0.1) 0%, rgba(228, 145, 166, 0.1) 100%);"></div>
          </div>

          <!-- Content -->
          <div class={index % 2 !== 0 ? 'order-1' : 'order-2'} style="direction:ltr;">
            <h3 style="font-size:1.8rem;font-weight:700;color:#225234;margin-bottom:15px;">{product.name}</h3>
            <p style="font-size:1.2rem;font-weight:600;color:#e491a6;margin-bottom:20px;">{product.price}</p>
            <p style="font-size:1rem;line-height:1.7;color:#225234;margin-bottom:30px;opacity:0.85;">{product.description}</p>
            <a
              href={product.etsyLink}
              target="_blank"
              rel="noopener noreferrer"
              class="shop-now-btn"
            >Shop Now</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .shop-now-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: #225234;
    color: #faf6f0;
    padding: 14px 32px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  .shop-now-btn:hover {
    background-color: #2d6b47;
    transform: translateY(-2px);
  }
  @media (max-width: 768px) {
    .product-row {
      grid-template-columns: 1fr !important;
      gap: 30px !important;
    }
    .product-image, .order-2 {
      order: 1 !important;
    }
    .product-image + div, .order-1 {
      order: 2 !important;
    }
    .product-row > div:first-child img {
      height: 280px !important;
    }
  }
</style>

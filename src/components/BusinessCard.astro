---
---
<section style="padding:100px 30px;background-color:#faf6f0;position:relative;">
  <div style="max-width:1200px;margin:0 auto;">
    <!-- Section Header -->
    <div style="text-align:center;margin-bottom:50px;">
      <h2 style="font-size:clamp(1.8rem, 4vw, 2.5rem);font-weight:700;color:#225234;margin-bottom:15px;">Connect With Us</h2>
      <p id="bc-subtitle" style="font-size:1.1rem;color:#e491a6;font-weight:500;">Hover the card to get in touch</p>
    </div>

    <!-- Flip Card -->
    <div style="display:flex;justify-content:center;perspective:1400px;">
      <div class="flip-card-bc" id="flip-card">
        <div class="flip-card-bc-inner">
          <!-- FRONT: full card image -->
          <div class="flip-front">
            <img src="/card2.png" alt="Hummico Designs business card" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" />
          </div>

          <!-- BACK: contact form -->
          <div class="flip-back">
            <div class="bc-thankyou" id="bc-thankyou" style="display:none;text-align:center;color:#faf6f0;">
              <div style="font-size:2.5rem;margin-bottom:12px;">🌿</div>
              <h4 style="font-size:1.3rem;font-weight:700;">Message sent!</h4>
              <p style="opacity:0.85;margin-top:6px;font-size:0.9rem;">We'll get back to you soon.</p>
            </div>
            <div class="bc-form-wrap" id="bc-form-wrap">
              <h4 style="font-size:clamp(1rem, 2.5vw, 1.2rem);font-weight:700;color:#ffffff;margin-bottom:14px;text-align:center;">Get In Touch</h4>
              <form id="bc-form" style="display:flex;flex-direction:column;gap:10px;">
                <input type="hidden" name="access_key" value="751bbde9-a623-46c8-85c3-fccb88cba6d5" />
                <input type="hidden" name="subject" value="New message from Hummico homepage business card" />
                <input class="contact-input" type="text" name="name" placeholder="Name" required />
                <input class="contact-input" type="email" name="email" placeholder="Email" required />
                <textarea class="contact-input" name="message" placeholder="Your message..." required rows="2" style="resize:none;"></textarea>
                <button type="submit" style="display:flex;align-items:center;justify-content:center;gap:8px;padding:10px;border-radius:10px;border:none;background-color:#225234;color:#faf6f0;font-weight:600;font-size:0.9rem;cursor:pointer;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 11 13"/><path d="M22 2 15 22 11 13 2 9z"/></svg>
                  Send
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-input::placeholder {
    color: rgba(255, 255, 255, 0.78);
  }
  /* Darker field so the WHITE text reads clearly on the green card face */
  .contact-input {
    padding: 9px 14px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.45);
    background: rgba(20, 56, 36, 0.55);
    color: #ffffff;
    font-size: 0.85rem;
    outline: none;
    font-family: inherit;
  }
  .contact-input:focus {
    border-color: #ffffff;
    background: rgba(20, 56, 36, 0.7);
  }
  .flip-card-bc {
    width: min(600px, 92vw);
    height: calc(min(600px, 92vw) * (2 / 3.5));
    position: relative;
    cursor: pointer;
  }
  .flip-card-bc-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .flip-card-bc:hover .flip-card-bc-inner,
  .flip-card-bc.flipped .flip-card-bc-inner {
    transform: rotateY(180deg) scale(1.14);
  }
  .flip-front, .flip-back {
    position: absolute;
    inset: 0;
    border-radius: 20px;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .flip-front {
    box-shadow: 0 30px 70px rgba(34,82,52,0.25);
  }
  .flip-back {
    height: auto;
    min-height: 100%;
    padding-bottom: 24px;
    transform: rotateY(180deg);
    overflow-y: auto;
    box-shadow: 0 30px 70px rgba(228,145,166,0.3);
    background: linear-gradient(135deg, #336855 0%, #387a51 100%);
    padding: clamp(12px, 3vw, 24px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
</style>

<script>
  const card = document.getElementById('flip-card');
  const subtitle = document.getElementById('bc-subtitle');
  const form = document.getElementById('bc-form') as HTMLFormElement | null;
  const formWrap = document.getElementById('bc-form-wrap');
  const thankyou = document.getElementById('bc-thankyou');

  const setSubtitle = (flipped: boolean) => {
    if (subtitle) subtitle.textContent = flipped ? 'Fill in the form to reach us' : 'Hover the card to get in touch';
  };

  card?.addEventListener('mouseenter', () => setSubtitle(true));
  card?.addEventListener('mouseleave', () => {
    if (!card.classList.contains('flipped')) setSubtitle(false);
  });
  card?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('#bc-form')) return;
    card.classList.toggle('flipped');
    setSubtitle(card.classList.contains('flipped'));
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });

      const result = await response.json();

      if (result.success) {
        if (formWrap) formWrap.style.display = 'none';
        if (thankyou) thankyou.style.display = 'block';
        setTimeout(() => {
          form.reset();
          if (formWrap) formWrap.style.display = 'block';
          if (thankyou) thankyou.style.display = 'none';
          card?.classList.remove('flipped');
          setSubtitle(false);
        }, 2500);
      } else {
        alert('Something went wrong. Please try again or email us directly at Hummicodesigns@gmail.com.');
      }
    } catch (error) {
      alert('Connection issue. Please try again or email us directly at Hummicodesigns@gmail.com.');
    }
  });
</script>

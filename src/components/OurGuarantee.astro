<section class="fda-banner-section" aria-label="FDA compliance and quality information">
  <!-- TODO_HUMMICO: Client-provided FDA compliance banner — replacing the previous Our Promise content -->
  <!-- TODO_HUMMICO: /fda-banner-mobile.png must exist in public/ — client to provide at 800x600px (4:3 mobile-friendly FDA banner). Until provided, mobile will fall through to /fda-banner.png. -->
  <picture>
    <source media="(max-width: 600px)" srcset="/fda-mobile-banner.png" />
    <img
      src="/fda-banner.png"
      alt="Hummico Designs FDA compliance and quality information"
      class="fda-banner-img"
    />
  </picture>
</section>

<style>
  /* The banner image IS the section's content. Desktop art is a wide 5:1 band, mobile a
     4:3 crop (swapped via the <picture> source above). Keep vertical spacing minimal so it
     integrates cleanly with the sections above and below. */
  .fda-banner-section {
    width: 100%;
    margin: 10px 0;
  }
  .fda-banner-section picture {
    display: block;
    width: 100%;
  }
  .fda-banner-img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>

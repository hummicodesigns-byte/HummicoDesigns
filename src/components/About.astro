---
---
<section id="about" class="about-section">
  <!-- Decorative Elements -->
  <div style="position:absolute;top:18%;left:4%;opacity:0.1;transform:rotate(-15deg);">
    <svg width="130" height="130" viewBox="0 0 150 150" fill="none">
      <ellipse cx="75" cy="75" rx="60" ry="20" stroke="#225234" stroke-width="1" fill="none" />
      <ellipse cx="75" cy="75" rx="40" ry="12" stroke="#225234" stroke-width="1" fill="none" />
      <line x1="75" y1="15" x2="75" y2="135" stroke="#225234" stroke-width="1" />
    </svg>
  </div>
  <div style="position:absolute;bottom:12%;right:5%;opacity:0.1;">
    <svg width="120" height="80" viewBox="0 0 120 80" fill="none">
      <path d="M10 70 Q30 10, 60 40 Q90 70, 110 30" stroke="#225234" stroke-width="2" fill="none" />
    </svg>
  </div>

  <div class="about-wrap">
    <div class="about-card">
      <p class="about-eyebrow">Sisters · Houston, TX</p>
      <h2 class="about-heading">Why Hummico Designs?</h2>
      <div class="about-divider"></div>
      <p class="about-body">
        Founded by two sisters in Houston, Hummico Designs exists to make people feel
        genuinely cared for, wellness gifts wrapped to feel personal, with luxury treated
        as a quiet act of self-respect.
      </p>
      <blockquote class="about-quote">
        "We don't just fill boxes.We craft experiences that feel as good to give as they are to receive."
      </blockquote>
      <a href="/about" class="about-story-btn">Our Story</a>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    padding: 96px 20px;
    background-color: #faf6f0;
    overflow: hidden;
  }
  /* max-width controls how WIDE the green card is (less side gutter when larger) */
  .about-wrap {
    max-width: 1040px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  /* padding controls how close the content sits to the card edges */
  .about-card {
    background-color: #225234;
    border-radius: 20px;
    padding: 40px 44px;
    box-shadow: 0 16px 50px rgba(34, 82, 52, 0.15);
    text-align: center;
  }
  .about-eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-size: 0.65rem;
    color: #e491a6;
    margin-bottom: 12px;
  }
  .about-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.6rem, 3.4vw, 2.3rem);
    color: #ffffff;
    line-height: 1.15;
  }
  .about-divider {
    width: 44px;
    height: 2px;
    background-color: #e491a6;
    margin: 18px auto 22px;
  }
  .about-body {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: clamp(0.85rem, 1.3vw, 0.98rem);
    line-height: 1.9;
    color: rgba(255,255,255,0.82);
    max-width: 680px;
    margin: 0 auto;
  }
  .about-quote {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    color: #e491a6;
    line-height: 1.6;
    max-width: 620px;
    margin: 26px auto 0;
  }
  .about-story-btn {
    display: inline-block;
    margin-top: 32px;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.78rem;
    text-decoration: none;
    padding: 14px 36px;
    border-radius: 50px;
    background-color: #e491a6;
    color: #ffffff;
    box-shadow: 0 8px 24px rgba(228,145,166,0.35);
    transition: background-color 0.3s ease, transform 0.2s ease;
  }
  .about-story-btn:hover {
    background-color: #d4788e;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .about-section {
      padding: 70px 18px;
    }
    .about-card {
      padding: 30px 20px;
    }
  }
</style>

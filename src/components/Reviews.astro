---
const ETSY_SHOP = 'https://www.etsy.com/shop/HummicoDesigns';

// TODO_HUMMICO: Replace these two PLACEHOLDER reviews with real Etsy reviews
// (reviewer first name + last initial, and their exact words). Keep the best two.
// Until then they are visibly marked "Placeholder" so nothing fake ships by accident.
const reviews = [
  {
    text: 'This is a great gift box to give to anyone in your life that loves tea. The items arrived super well packed with a very cute stamp on it. Everything is very customized and the tea quality is amazing! Would definitely buy again !!',
    name: 'Arshya',
    rating: 5,
  },
  {
    text: 'Absolutely loved it! Everything arrived beautifully and securely packed with so much care and attention to detail. I especially appreciated that each tube was sealed individually, it really made the box feel extra clean, fresh, and high quality. The cup & saucer candle made the whole box feel extra elegant and luxurious. Highly recommend',
    name: 'Mahboubeh',
    rating: 5,
  },
];
---

<section class="reviews-section">
  <!-- Decorative element (matches other sections) -->
  <div style="position:absolute;top:12%;right:4%;opacity:0.1;">
    <svg width="110" height="60" viewBox="0 0 120 60" fill="none">
      <path d="M10 30 Q30 10, 60 30 Q90 50, 110 30" stroke="#225234" stroke-width="2" fill="none" />
    </svg>
  </div>

  <div class="reviews-inner">
    <div style="text-align:center;margin-bottom:50px;">
      <p class="reviews-eyebrow">Kind words</p>
      <h2 class="reviews-title">Loved, gifted, <span>and remembered.</span></h2>
    </div>

    <!-- Single-review carousel: every review is real HTML; inactive ones are clipped by the
         viewport (overflow:hidden) and the track is moved with translateX. JS only switches
         which one is shown (arrows + finger swipe); it never injects text. -->
    <div class="reviews-carousel" data-reviews-carousel>
      <button class="review-arrow prev" data-prev type="button" aria-label="Previous review">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>

      <div class="reviews-viewport" data-reviews-viewport>
        <div class="reviews-track" data-reviews-track>
          {reviews.map((review) => (
            <div class="review-slide">
              <figure class="review-card">
                <span class="review-placeholder-tag">Placeholder</span>
                <div class="review-stars" aria-label={`${review.rating} out of 5 stars`}>
                  {Array.from({ length: review.rating }).map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#e491a6" stroke="#e491a6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  ))}
                </div>
                <blockquote class="review-text">“{review.text}”</blockquote>
                <figcaption class="review-name">{review.name}</figcaption>
              </figure>
            </div>
          ))}
        </div>
      </div>

      <button class="review-arrow next" data-next type="button" aria-label="Next review">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <div style="display:flex;justify-content:center;margin-top:48px;">
      <a href={ETSY_SHOP} target="_blank" rel="noopener noreferrer" class="reviews-etsy-btn">Shop on Etsy</a>
    </div>
  </div>
</section>

<style>
  .reviews-section {
    padding: 100px 20px;
    background-color: #faf6f0;
    position: relative;
    overflow: hidden;
  }
  .reviews-inner {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .reviews-eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: #e491a6;
    margin-bottom: 14px;
  }
  .reviews-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-style: normal;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    color: #225234;
    line-height: 1.15;
  }
  .reviews-title span {
    font-style: italic;
    font-weight: 300;
    color: #e491a6;
  }

  /* ── Carousel: card centered, arrows flank it (desktop) ── */
  .reviews-carousel {
    position: relative;
    max-width: 860px;
    margin: 0 auto;
    /* horizontal room so the flanking arrows never sit over the card text */
    padding: 0 72px;
  }
  .reviews-viewport {
    overflow: hidden;
  }
  .reviews-track {
    display: flex;
    flex-wrap: nowrap;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  .review-slide {
    flex: 0 0 100%;
    min-width: 100%;
    display: flex;
    justify-content: center;
    padding: 6px 4px;
  }
  .review-card {
    position: relative;
    width: 100%;
    max-width: 660px;
    background-color: #ffffff;
    border: 1px solid rgba(34, 82, 52, 0.08);
    border-radius: 18px;
    padding: 46px 44px;
    box-shadow: 0 14px 40px rgba(34, 82, 52, 0.06);
    margin: 0;
  }
  .review-placeholder-tag {
    position: absolute;
    top: 16px;
    right: 16px;
    font-family: 'Jost', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #b06b7d;
    background: rgba(228, 145, 166, 0.14);
    border: 1px dashed rgba(228, 145, 166, 0.6);
    border-radius: 20px;
    padding: 3px 10px;
  }
  .review-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 22px;
  }
  .review-text {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 1.7vw, 1.4rem);
    line-height: 1.6;
    color: #225234;
    margin-bottom: 24px;
  }
  .review-name {
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: #e491a6;
  }

  /* Arrows */
  .review-arrow {
    position: absolute;
    top: 50%;
    margin-top: -26px;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: none;
    background-color: #225234;
    color: #faf6f0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 26px rgba(34, 82, 52, 0.22);
    transition: background-color 0.25s ease, transform 0.2s ease;
    z-index: 3;
  }
  .review-arrow.prev { left: 0; }
  .review-arrow.next { right: 0; }
  .review-arrow:hover { background-color: #2d6b47; transform: scale(1.07); }

  .reviews-etsy-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: #225234;
    color: #faf6f0;
    padding: 14px 36px;
    border-radius: 30px;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.82rem;
    transition: all 0.3s ease;
  }
  .reviews-etsy-btn:hover {
    background-color: #2d6b47;
    transform: translateY(-2px);
  }

  /* ── Mobile (<=768px): one review fills the screen; arrows straddle the card's L/R edges ── */
  @media (max-width: 768px) {
    .reviews-carousel {
      padding: 0; /* no gutters; the slide inset (below) makes room for the overlapping arrows */
    }
    .review-slide {
      padding: 6px 26px; /* insets the card so each arrow sits half-on / half-off its edge */
    }
    .review-card {
      padding: 34px 30px;
    }
    .review-arrow {
      top: 50%;
      bottom: auto;
      margin-top: -26px; /* vertically centered on the card */
      width: 52px;
      height: 52px;
    }
    /* left:0 / right:0 places the 52px arrow centered on the card edge (card starts 26px in) */
    .review-arrow.prev { left: 0; right: auto; }
    .review-arrow.next { right: 0; left: auto; }
  }
</style>

<script>
  // Scope every lookup to THIS carousel — other sections (e.g. Philosophy) also use
  // data-track, so an unscoped document.querySelector('[data-track]') would grab the wrong one.
  const root = document.querySelector<HTMLElement>('[data-reviews-carousel]');
  const track = root?.querySelector<HTMLElement>('[data-reviews-track]');
  const viewport = root?.querySelector<HTMLElement>('[data-reviews-viewport]');
  const prev = root?.querySelector<HTMLElement>('[data-prev]');
  const next = root?.querySelector<HTMLElement>('[data-next]');

  if (track && viewport && prev && next) {
    const count = track.children.length;
    let index = 0;

    const go = (i: number) => {
      index = ((i % count) + count) % count; // wrap/loop both ways
      track.style.transform = `translateX(-${index * 100}%)`;
    };

    prev.addEventListener('click', () => go(index - 1));
    next.addEventListener('click', () => go(index + 1));

    // Finger swipe on mobile
    let startX = 0;
    let dragging = false;
    viewport.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      dragging = true;
    }, { passive: true });
    viewport.addEventListener('touchend', (e) => {
      if (!dragging) return;
      dragging = false;
      const delta = e.changedTouches[0].clientX - startX;
      if (Math.abs(delta) > 40) go(delta < 0 ? index + 1 : index - 1);
    });

    go(0);
  }
</script>

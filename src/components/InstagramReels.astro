---
const instagramReels = [
  { id: 1, video: '/hummico-video.mp4', title: 'Every box is carefully packed by hand with love', views: '12.5K' },
  { id: 2, video: '/reel2.mp4', title: 'Morning Routine with Wellness Tea', views: '8.2K' },
  { id: 3, video: '/reel3.mp4', title: 'The Gift That Never Gets Old', views: '15.1K' },
];
---

<section style="padding:100px 20px;background-color:#faf6f0;position:relative;">
  <!-- Decorative Elements -->
  <div style="position:absolute;top:5%;left:4%;opacity:0.1;transform:rotate(-20deg);">
    <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
      <path d="M50 10 L80 30 L80 70 L50 90 L20 70 L20 30 Z" stroke="#225234" stroke-width="1" fill="none" />
    </svg>
  </div>

  <div style="max-width:1100px;margin:0 auto;">
    <!-- Section Header -->
    <div style="text-align:center;margin-bottom:50px;">
      <h2 style="font-size:2.5rem;font-weight:700;color:#225234;margin-bottom:15px;">Let's Get Social</h2>
      <p style="font-size:1.1rem;color:#e491a6;font-weight:500;max-width:600px;margin:0 auto;line-height:1.6;">
        Follow us @hummico.design for daily wellness tips, unboxing videos,
        and behind-the-scenes content
      </p>
    </div>

    <!-- Reels Grid -->
    <div class="reels-grid">
      {instagramReels.map((reel) => (
        <div class="reel-card" data-reel style="position:relative;border-radius:20px;overflow:hidden;cursor:pointer;aspect-ratio:9/16;background-color:#000;">
          <video class="reel-video" src={reel.video} style="width:100%;height:100%;object-fit:cover;" playsinline loop></video>
          <div class="reel-overlay" style="position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.08) 32%, transparent 58%);display:flex;flex-direction:column;justify-content:flex-end;padding:20px;">
            <!-- Play Button -->
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%, -50%);background-color:rgba(255,255,255,0.9);border-radius:50%;width:60px;height:60px;display:flex;align-items:center;justify-content:center;box-shadow:0 10px 30px rgba(0,0,0,0.2);">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#225234" stroke="#225234" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
            </div>
            <!-- Title and Views -->
            <h3 style="font-size:1rem;font-weight:600;color:#fff;margin-bottom:5px;">{reel.title}</h3>
            <p style="font-size:0.85rem;color:#faf6f0;">{reel.views} views</p>
          </div>
        </div>
      ))}
    </div>

    <!-- View More Button -->
    <div style="text-align:center;margin-top:40px;">
      <a href="https://www.instagram.com/hummico_designs/" target="_blank" rel="noopener noreferrer" class="view-more-btn">
        View More on Instagram
      </a>
    </div>
  </div>
</section>

<style>
  .view-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: transparent;
    color: #225234;
    padding: 14px 32px;
    border-radius: 30px;
    border: 2px solid #225234;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  .view-more-btn:hover {
    background-color: #225234;
    color: #faf6f0;
  }
  /* Centered flex so the three reels stay balanced; any wrap centers (no left-shift) */
  .reels-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 30px;
  }
  .reel-card {
    width: min(300px, 78vw);
    max-width: 100%;
  }
  @media (max-width: 600px) {
    .reels-grid {
      gap: 22px;
    }
    .reel-card {
      width: min(320px, 86vw);
    }
  }
</style>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.reel-card'));
  const videos = cards.map((c) => c.querySelector('video') as HTMLVideoElement);

  cards.forEach((card, i) => {
    const video = videos[i];
    const overlay = card.querySelector<HTMLElement>('.reel-overlay');
    card.addEventListener('click', () => {
      if (!video.paused) {
        video.pause();
        return;
      }
      videos.forEach((v) => v !== video && v.pause());
      video.play();
    });
    video.addEventListener('play', () => { if (overlay) overlay.style.display = 'none'; });
    video.addEventListener('pause', () => { if (overlay) overlay.style.display = 'flex'; });
  });
</script>

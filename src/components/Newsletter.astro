---
const SUBSCRIBE_URL = 'https://www.alura.io/subscribe?=HummicoDesigns';
---

<!-- Full-width, edge-to-edge band (like the hero/footer). -->
<!-- TODO_HUMMICO: Replace the placeholder image in `.newsletter` background-image (the url
     after the gradient) with the real photo (calming/lifestyle, ~1920x800). Keep the dark
     green gradient layered in front of it so the white text + button stay readable. -->
<section class="newsletter" aria-label="Subscribe to the Hummico letter">
  <div class="nl-inner">
    <p class="nl-eyebrow">The Hummico letter</p>
    <h2 class="nl-title">Little rituals, <span>straight to your inbox.</span></h2>
    <p class="nl-body">
      Slow moments, new collections, and gentle gifting ideas — sent now and then, never too often.
    </p>
    <a
      href={SUBSCRIBE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="nl-btn"
    >Subscribe</a>
    <p class="nl-note">Unsubscribe anytime.</p>
  </div>
</section>

<style>
  .newsletter {
    width: 100%;
    /* Dark green overlay baked into the background so text stays readable over the photo.
       The url(...) is the swappable placeholder image. Higher gradient alpha = more muted image. */
    background-image:
      linear-gradient(180deg, rgba(20,46,30,0.40) 0%, rgba(3, 4, 4, 0.9) 100%),
      url('/newsletter.avif');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    /* Compact band; gently rounded TOP corners only, square bottom to meet the footer. */
    padding: 44px 20px;
    border-radius: 18px 18px 0 0;
    display: flex;
    justify-content: center;
  }
  .nl-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 680px;
    width: 100%;
  }
  .nl-eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: #e491a6;
    margin: 0 0 12px;
  }
  .nl-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(1.7rem, 3.6vw, 2.5rem);
    line-height: 1.14;
    color: #ffffff;
    margin: 0;
  }
  .nl-title span {
    font-style: italic;
    font-weight: 300;
    color: #f5e8d8;
  }
  .nl-body {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: clamp(0.88rem, 1.3vw, 1rem);
    line-height: 1.7;
    color: rgba(250, 246, 240, 0.85);
    max-width: 460px;
    margin: 14px 0 0;
  }
  .nl-btn {
    display: inline-block;
    margin: 26px 0 0;
    font-family: 'Jost', sans-serif;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.82rem;
    text-decoration: none;
    padding: 15px 46px;
    border-radius: 50px;
    background-color: #e491a6;
    color: #ffffff;
    box-shadow: 0 12px 30px rgba(228, 145, 166, 0.5);
    transition: background-color 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
  }
  .nl-btn:hover {
    background-color: #d4788e;
    transform: translateY(-2px);
    box-shadow: 0 16px 38px rgba(228, 145, 166, 0.6);
  }
  .nl-note {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: rgba(250, 246, 240, 0.6);
    margin: 16px 0 0;
  }

  @media (max-width: 768px) {
    .newsletter { padding: 36px 18px; }
    .nl-btn { width: 100%; max-width: 280px; padding: 15px 24px; }
  }
</style>

---

<!-- Full-width, edge-to-edge band (like the hero/footer). -->
<!-- TODO_HUMMICO: Replace the placeholder image in `.newsletter` background-image (the url
     after the gradient) with the real photo (calming/lifestyle, ~1920x800). Keep the dark
     green gradient layered in front of it so the white text + form stay readable. -->
<section class="newsletter" aria-label="Subscribe to the Hummico letter">
  <div class="nl-inner">
    <p class="nl-eyebrow">The Hummico letter</p>
    <h2 class="nl-title">Little rituals, <span>straight to your inbox.</span></h2>
    <p class="nl-body">
      Slow moments, new collections, gentle gifting ideas, plus exclusive subscriber offers and
      discounts. Sent now and then, never too often.
    </p>

    <!-- One unified pill bar: name | email | subscribe. novalidate → custom messages only. -->
    <form id="nl-form" class="nl-form" novalidate>
      <input
        type="text"
        name="name"
        id="nl-name"
        class="nl-input nl-input--name"
        placeholder="Your name"
        autocomplete="name"
        aria-label="Your name"
      />
      <input
        type="email"
        name="email"
        id="nl-email"
        class="nl-input nl-input--email"
        placeholder="Your email"
        autocomplete="email"
        aria-label="Your email"
      />
      <button type="submit" class="nl-btn" id="nl-submit">Subscribe</button>
    </form>

    <!-- Inline, warm-toned message (validation / coming-soon / error). Fades in. -->
    <p class="nl-msg" id="nl-msg" role="alert"></p>

    <!-- Shown only on successful subscribe (real token in place); replaces the form. -->
    <div class="nl-success" id="nl-success" hidden>
      <p class="nl-success-title">Welcome to the <span>slow morning club.</span></p>
      <p class="nl-success-sub">Watch your inbox for our first letter.</p>
    </div>

    <p class="nl-note">Unsubscribe anytime.</p>
  </div>
</section>

<style>
  .newsletter {
    width: 100%;
    /* Dark green overlay baked into the background so text stays readable over the photo.
       The url(...) is the swappable placeholder image. Higher gradient alpha = more muted image. */
    background-image:
      linear-gradient(180deg, rgba(20,46,30,0.40) 0%, rgba(3, 4, 4, 0.9) 100%),
      url('/newsletter.avif');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    /* Compact band; gently rounded TOP corners only, square bottom to meet the footer. */
    padding: 44px 20px;
    border-radius: 18px 18px 0 0;
    display: flex;
    justify-content: center;
  }
  .nl-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 680px;
    width: 100%;
  }
  .nl-eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: #e491a6;
    margin: 0 0 12px;
  }
  .nl-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(1.7rem, 3.6vw, 2.5rem);
    line-height: 1.14;
    color: #ffffff;
    margin: 0;
  }
  .nl-title span {
    font-style: italic;
    font-weight: 300;
    color: #f5e8d8;
  }
  .nl-body {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: clamp(0.88rem, 1.3vw, 1rem);
    line-height: 1.7;
    color: rgba(250, 246, 240, 0.85);
    max-width: 460px;
    margin: 14px 0 0;
  }

  /* ── Subscription form: one unified pill bar ── */
  .nl-form {
    display: flex;
    align-items: stretch;
    width: 100%;
    max-width: 720px;
    height: 62px;
    margin: 28px auto 0;
    background: rgba(250, 246, 240, 0.96);
    border: 1px solid rgba(34, 82, 52, 0.15);
    border-radius: 999px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }
  .nl-input {
    min-width: 0;
    box-sizing: border-box;
    border: none;
    background: transparent;
    padding: 0 24px;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    font-size: 15px;
    color: #225234;
    transition: background-color 0.25s ease;
  }
  .nl-input::placeholder {
    color: rgba(34, 82, 52, 0.55);
    font-style: italic;
  }
  .nl-input:focus {
    outline: none;
    background-color: rgba(255, 255, 255, 0.3);
  }
  .nl-input--name {
    flex: 0 0 30%;
    border-right: 1px solid rgba(34, 82, 52, 0.15);
  }
  .nl-input--email {
    flex: 1 1 40%;
    border-right: 1px solid rgba(34, 82, 52, 0.15);
  }
  .nl-btn {
    flex: 0 0 30%;
    border: none;
    outline: none;
    background-color: #e491a6;
    color: #faf6f0;
    font-family: 'Jost', sans-serif;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .nl-btn:hover,
  .nl-btn:focus { background-color: #d97a92; }
  .nl-btn:active { transform: scale(0.98); }
  .nl-btn:disabled { opacity: 0.7; cursor: default; transform: none; }

  /* Inline message (validation / coming-soon / error) — warm rose, gentle fade-in */
  .nl-msg {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 14px;
    line-height: 1.4;
    color: #e491a6;
    text-shadow: 0 0 8px rgba(228, 145, 166, 0.4);
    min-height: 1.2em;
    margin: 16px 0 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .nl-msg.is-visible { opacity: 1; }

  /* Success state — replaces the form */
  .nl-success { margin: 26px 0 0; }
  .nl-success-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(1.3rem, 2.6vw, 1.8rem);
    line-height: 1.2;
    color: #faf6f0;
    margin: 0;
  }
  .nl-success-title span { font-style: italic; font-weight: 300; color: #f5e8d8; }
  .nl-success-sub {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: rgba(250, 246, 240, 0.7);
    margin: 10px 0 0;
  }

  .nl-note {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: rgba(250, 246, 240, 0.6);
    margin: 16px 0 0;
  }

  /* ── Mobile: stack into three full-width pills ── */
  @media (max-width: 600px) {
    .newsletter { padding: 36px 18px; }
    .nl-form {
      flex-direction: column;
      align-items: stretch;
      height: auto;
      max-width: 420px;
      gap: 8px;
      background: transparent;
      border: none;
      box-shadow: none;
      overflow: visible;
    }
    .nl-input,
    .nl-btn {
      width: 100%;
      flex: 0 0 auto;
      height: 52px;
      border-radius: 999px;
    }
    .nl-input {
      background: rgba(250, 246, 240, 0.96);
      border: 1px solid rgba(34, 82, 52, 0.15);
      border-right: 1px solid rgba(34, 82, 52, 0.15); /* override the divider rule */
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    }
  }
</style>

<script>
  // TODO_HUMMICO: Add MailerLite API token and group ID once client creates account.
  // Replace MAILERLITE_TOKEN and MAILERLITE_GROUP_ID below.
  const MAILERLITE_TOKEN = 'TODO_HUMMICO_REPLACE_WITH_REAL_TOKEN';
  const MAILERLITE_GROUP_ID = 'TODO_HUMMICO_REPLACE_WITH_REAL_GROUP_ID';

  const form = document.getElementById('nl-form') as HTMLFormElement | null;
  const nameInput = document.getElementById('nl-name') as HTMLInputElement | null;
  const emailInput = document.getElementById('nl-email') as HTMLInputElement | null;
  const submitBtn = document.getElementById('nl-submit') as HTMLButtonElement | null;
  const msg = document.getElementById('nl-msg');
  const success = document.getElementById('nl-success');

  function showMsg(text: string) {
    if (!msg) return;
    msg.textContent = text;
    msg.classList.add('is-visible');
  }
  function clearMsg() {
    if (!msg) return;
    msg.classList.remove('is-visible');
  }

  if (form && nameInput && emailInput && submitBtn && msg && success) {
    // Message fades away as soon as the user starts correcting their input.
    nameInput.addEventListener('input', clearMsg);
    emailInput.addEventListener('input', clearMsg);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = nameInput.value.trim();
      const email = emailInput.value.trim();

      // Manual, friendly validation (browser defaults are suppressed via novalidate).
      if (!name) {
        showMsg('Please share your name so we know who to greet');
        nameInput.focus();
        return;
      }
      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      if (!emailOk) {
        showMsg("That email doesn't look quite right — try again?");
        emailInput.focus();
        return;
      }

      // Not wired up yet — gently note it instead of calling the API.
      if (MAILERLITE_TOKEN.startsWith('TODO_HUMMICO')) {
        showMsg('Sign-ups open soon — check back shortly.');
        return;
      }

      submitBtn.disabled = true;
      try {
        const res = await fetch('https://connect.mailerlite.com/api/subscribers', {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${MAILERLITE_TOKEN}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            email,
            fields: { name },
            groups: [MAILERLITE_GROUP_ID],
          }),
        });

        if (!res.ok) throw new Error(`MailerLite responded ${res.status}`);

        // Replace the form with the warm welcome confirmation.
        clearMsg();
        form.hidden = true;
        success.hidden = false;
      } catch (err) {
        submitBtn.disabled = false;
        showMsg('Something went wrong — please try again later.');
      }
    });
  }
</script>

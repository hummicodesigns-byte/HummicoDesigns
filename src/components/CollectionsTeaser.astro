---
const ETSY_SHOP = 'https://www.etsy.com/shop/HummicoDesigns';

// Lean teaser that funnels to the full Collections page (built in a later step).
// TODO_HUMMICO: Swap these three tiles for your chosen "featured" product photos.
// These are stand-ins pulled from existing imagery; the full grids now live on /collections.
const tiles = [
  { image: '/herbal-tea-candle-infuser.avif', label: 'Best Sellers', link: '/collections#best-sellers' },
  { image: '/birthday-tea-gift.avif', label: 'Collections', link: '/collections#our-collections' },
  { image: '/herbal-tea-honey-candle.avif', label: 'Featured GIfts', link: '/collections#featured-gifts' },
];
---

<section class="collections-teaser" aria-label="Explore our collections">
  <div class="ct-inner">
    <div style="text-align:center;margin-bottom:54px;">
      <p class="ct-eyebrow">The full collection</p>
      <h2 class="ct-title">Curated boxes, <span>made to be gifted.</span></h2>
      <p class="ct-lede">
        Herbal tea gift sets, self-care rituals, and quiet luxuries. Explore the full
        range, or shop them directly on Etsy.
      </p>
    </div>

    <div class="ct-grid">
      {tiles.map((tile) => (
        <a href={tile.link} class="ct-tile" aria-label={`${tile.label} — view collections`}>
          <img src={tile.image} alt={tile.label} loading="lazy" />
          <span class="ct-tile-overlay"></span>
          <span class="ct-tile-label">{tile.label}</span>
        </a>
      ))}
    </div>

    <div class="ct-buttons">
      <a href="/collections" class="ct-btn-primary">Explore Collections</a>
      <a href={ETSY_SHOP} target="_blank" rel="noopener noreferrer" class="ct-btn-secondary">Shop on Etsy</a>
    </div>

    <p class="ct-etsy-note">You'll complete your order securely on Etsy.</p>
  </div>
</section>

<style>
  .collections-teaser {
    padding: 70px 20px;
    background-color: #faf6f0;
    position: relative;
    overflow: hidden;
  }
  .ct-inner {
    max-width: 1140px;
    margin: 0 auto;
  }
  .ct-eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: #b06b7d;
    margin-bottom: 16px;
  }
  .ct-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(2rem, 4.4vw, 3rem);
    color: #225234;
    line-height: 1.12;
  }
  .ct-title span {
    font-style: italic;
    font-weight: 300;
    color: #c77d92;
  }
  .ct-lede {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: clamp(0.9rem, 1.4vw, 1rem);
    color: #225234;
    opacity: 0.78;
    margin: 16px auto 0;
    max-width: 540px;
    line-height: 1.75;
  }
  .ct-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 52px;
  }
  .ct-tile {
    position: relative;
    display: block;
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: 0 18px 45px rgba(34, 82, 52, 0.14);
    text-decoration: none;
  }
  .ct-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .ct-tile:hover img {
    transform: scale(1.06);
  }
  .ct-tile-overlay {
    position: absolute;
    inset: 0;
    /* Subtle darkening only at the very bottom, just enough for label legibility */
    background: linear-gradient(to top, rgba(20,46,30,0.55) 0%, rgba(20,46,30,0.12) 28%, transparent 55%);
  }
  .ct-tile-label {
    position: absolute;
    left: 24px;
    bottom: 22px;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: #faf6f0;
  }
  .ct-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .ct-etsy-note {
    text-align: center;
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    color: #225234;
    opacity: 0.62;
    margin: 16px 0 0;
  }
  .ct-btn-primary, .ct-btn-secondary {
    font-family: 'Jost', sans-serif;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.82rem;
    text-decoration: none;
    padding: 15px 38px;
    border-radius: 50px;
    transition: all 0.3s ease;
  }
  .ct-btn-primary {
    background-color: #225234;
    color: #faf6f0;
    border: 2px solid #225234;
  }
  .ct-btn-primary:hover {
    background-color: #2d6b47;
    border-color: #2d6b47;
    transform: translateY(-2px);
  }
  .ct-btn-secondary {
    background-color: transparent;
    color: #225234;
    border: 2px solid #225234;
  }
  .ct-btn-secondary:hover {
    background-color: #225234;
    color: #faf6f0;
    transform: translateY(-2px);
  }
  @media (max-width: 900px) {
    .ct-grid { grid-template-columns: 1fr; gap: 18px; max-width: 380px; margin: 0 auto 46px; }
  }
</style>
